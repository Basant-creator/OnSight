# Required for Render Deployment
NODE_ENV=production
PORT=5000

# MongoDB Connection (MongoDB Atlas recommended for production)
MONGO_URI=mongodb://localhost:27017/practice_exam_db

# JWT Secrets (Generate strong random strings - min 32 chars)
JWT_SECRET=your-super-secret-jwt-access-token-key-change-in-production
JWT_REFRESH_SECRET=your-super-secret-jwt-refresh-token-key-change-in-production

# Frontend URL (Your Vercel deployment URL)
FRONTEND_URL=http://localhost:5500

# REQUIRED: Google Gemini API for PDF parsing
# Get your key at: https://ai.google.dev/
GEMINI_API_KEY=AIza-your-actual-gemini-api-key
